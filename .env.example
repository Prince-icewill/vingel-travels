# Copy this file to .env and fill in your real Formspree endpoints.
# Get these by creating two forms at https://formspree.io (free, no card required):
#   1. One form for consultation bookings
#   2. One form for general contact messages
# Each form gives you an endpoint URL like: https://formspree.io/f/abc123xy
#
# IMPORTANT: variable names must start with REACT_APP_ or Create React App
# will not expose them to the browser. Restart `npm start` after editing .env.

REACT_APP_BOOKING_FORM_ENDPOINT=https://formspree.io/f/your-booking-form-id
REACT_APP_CONTACT_FORM_ENDPOINT=https://formspree.io/f/your-contact-form-id

# Google Analytics 4 — get this from https://analytics.google.com after
# creating a GA4 property. Looks like G-XXXXXXXXXX. Leave blank to disable
# analytics entirely (safe default for local development).
REACT_APP_GA_MEASUREMENT_ID=
